{
  "manifest_version": 3,
  "name": "Bukmarks Extension",
  "version": "1.1.0",
  "description": "Save the current page and import browser bookmarks into Bukmarks.",
  "permissions": ["activeTab", "bookmarks", "storage"],
  "host_permissions": [
    "https://bukmarks.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@bukmarks.app",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://bukmarks.vercel.app/*", "http://localhost:3000/*"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
